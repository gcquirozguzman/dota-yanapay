# Copia este archivo como .env y reemplaza los valores de ejemplo.
# Nunca guardes claves reales en .env.example.

# Token local compartido entre el servidor y el archivo GSI de Dota 2.
GSI_AUTH_TOKEN=cambia-este-token

# Servidor GSI local.
GSI_HOST=127.0.0.1
GSI_PORT=3000
# Opcional si el instalador no detecta automaticamente Dota 2.
DOTA2_PATH=

# Proveedor de consejos tacticos.
AI_PROVIDER=deepseek
AI_MODEL=deepseek-v4-flash
AI_REQUEST_TIMEOUT_MS=4000
AI_MIN_INTERVAL_MS=5000

# API oficial de DeepSeek. Coloca la clave real solamente en .env.
DEEPSEEK_API_KEY=reemplaza-con-tu-api-key
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Agente flotante, voz y vision local.
VOICE_ENABLED=true
VOICE_LOCALE=es-ES
VOICE_LISTEN_SECONDS=8
VOICE_ENGINE=faster-whisper
WAKE_WORD_ENABLED=true
WAKE_WORD=yanapay
WAKE_WORD_TIMEOUT_SECONDS=10
WAKE_WORD_CONFIDENCE=0.25
WHISPER_MODEL=small
VOICE_HOTWORDS=Yanapay héroe héroes Dota Crystal Maiden contrapick Roshan Radiant Dire
VOICE_ENERGY_THRESHOLD=auto
VOICE_SILENCE_SECONDS=0.8
VOICE_MAX_UTTERANCE_SECONDS=15
VISION_ENABLED=true
VISION_INTERVAL_MS=250
VISION_DEBUG=false
PYTHON_COMMAND=python
